{
  "version": 3,

  "global": {
    "environmentIntensity": 1.0,
    "exposure": 1.0
  },

  "weatherLighting": {
    "sunny-day": {
      "environmentIntensity": 1.3,
      "exposure": 1.2,
      "backgroundColor": "#b9e8ff",
      "directionalLight": {
        "enabled": true,
        "intensity": 2.4,
        "color": "#fff4d6",
        "angle": 45
      },
      "ambientLight": {
        "intensity": 1.1,
        "color": "#ffffff"
      },
      "bloom": false,
      "contactShadows": true,
      "softShadows": true
    },

    "rainy-day": {
      "environmentIntensity": 0.9,
      "exposure": 0.95,
      "backgroundColor": "#94a8b8",
      "directionalLight": {
        "enabled": true,
        "intensity": 1.1,
        "color": "#dbe5ef",
        "angle": 65
      },
      "ambientLight": {
        "intensity": 0.7,
        "color": "#d4dde6"
      },
      "bloom": false,
      "contactShadows": true,
      "softShadows": true
    },

    "clear-night": {
      "environmentIntensity": 0.55,
      "exposure": 0.82,
      "backgroundColor": "#07111c",
      "moonLight": {
        "enabled": true,
        "intensity": 0.7,
        "color": "#dce8ff",
        "angle": 30
      },
      "ambientLight": {
        "intensity": 0.42,
        "color": "#7f9cc4"
      },
      "bloom": true,
      "contactShadows": true,
      "softShadows": true
    },

    "rainy-night": {
      "environmentIntensity": 0.45,
      "exposure": 0.72,
      "backgroundColor": "#040a12",
      "moonLight": {
        "enabled": true,
        "intensity": 0.4,
        "color": "#aebfd8",
        "angle": 25
      },
      "ambientLight": {
        "intensity": 0.35,
        "color": "#5e789c"
      },
      "bloom": true,
      "contactShadows": true,
      "softShadows": true
    }
  },

  "presets": [
    {
      "id": "entrance-lighting",
      "ambient": 0.7,
      "spotlights": [
        "entrance-spot"
      ]
    },
    {
      "id": "workspace-lighting",
      "ambient": 0.65,
      "spotlights": [
        "desk-light"
      ],
      "emissive": [
        "monitor-right",
        "monitor-center",
        "monitor-left"
      ]
    },
    {
      "id": "library-lighting",
      "ambient": 0.65,
      "spotlights": [
        "bookshelf-light"
      ]
    },
    {
      "id": "server-lighting",
      "ambient": 0.55,
      "spotlights": [
        "server-light"
      ],
      "emissive": [
        "server-rack"
      ]
    },
    {
      "id": "certificate-lighting",
      "ambient": 0.65,
      "spotlights": [
        "certificate-light"
      ]
    },
    {
      "id": "window-lighting",
      "ambient": 0.55
    },
    {
      "id": "lab-lighting",
      "ambient": 0.5,
      "spotlights": [
        "prototype-light",
        "terminal-light"
      ],
      "emissive": [
        "floating-display",
        "ai-terminal"
      ]
    }
  ],

  "effects": {
    "monitorGlow": true,
    "bloom": true,
    "contactShadows": true,
    "softShadows": true,
    "autoExposure": true,
    "volumetricLight": true
  }
}